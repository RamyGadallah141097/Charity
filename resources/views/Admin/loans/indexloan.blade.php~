@section('ajaxCalls')
    <script>
        $(document).ready(function () {
            var borrowerId = "{{ $id }}";

            var table = $('#dataTable').DataTable({
                processing: true,
                serverSide: true,
                ajax: "{{ route('person.loans', ':id') }}".replace(':id', borrowerId),
                columns: [
                    { data: 'id', name: 'id' },
                    { data: 'borrower_name', name: 'borrower_name' },
                    { data: 'borrower_phone', name: 'borrower_phone' },
                    { data: 'amount', name: 'amount' },
                    { data: 'month', name: 'month' },
                    { data: 'status', name: 'status' },
                    { data: 'action', name: 'action', orderable: false, searchable: false }
                ]
            });

            $(document).on('click', '.delete-btn', function () {
                let loanId = $(this).data('id');

                if (confirm("هل أنت متأكد من حذف هذا القرض؟")) {
                    $.ajax({
                        url: "{{ route('loan.delete', ':id') }}".replace(':id', loanId),
                        type: 'DELETE',
                        data: { _token: '{{ csrf_token() }}' },
                        success: function(response) {
                            alert(response.message);
                            table.ajax.reload();
                        },
                        error: function(response) {
                            alert(response.responseJSON.error);
                        }
                    });
                }
            });

            // ✅ Pay Loan (Update Status)
            $(document).on('click', '.pay-btn', function () {
                let loanId = $(this).data('id');

                if (confirm("هل أنت متأكد من دفع هذا القرض؟")) {
                    $.ajax({
                        url: "{{ route('loan.pay', ':id') }}".replace(':id', loanId),
                        type: 'POST',
                        data: { _token: '{{ csrf_token() }}' },
                        success: function(response) {
                            alert(response.message);
                            table.ajax.reload();
                        },
                        error: function(response) {
                            alert(response.responseJSON.error);
                        }
                    });
                }
            });

        });
    </script>
